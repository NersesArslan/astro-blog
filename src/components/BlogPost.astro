---
const { title, url, pubDate, description } = Astro.props;
---

<li class="post-preview">
  <a href={url} class="post-link"
    ><h2>{title}</h2>
    <p class="post-description">{description}</p>
    <p class="post-date">{pubDate}</p></a
  >
</li>

<style>
  .post-preview {
    padding: 1.5rem 0;
    border-bottom: 1px solid #edf2f7;
    transition: transform 0.15s ease;
  }

  .post-preview a {
    display: block;
    font-size: 1.45rem;
    font-weight: 700;
    line-height: 1.35;
    color: #0f172a;
    text-decoration: none;
    margin-bottom: 0.35rem;
    transform: translateY(-1px);
  }

  .post-preview a:hover {
    color: #2563eb;
    text-decoration: underline;
  }

  .post-date {
    margin: 0;
    font-size: 0.95rem;
    color: #64748b;
    font-family: Arial, Helvetica, sans-serif;
  }

  .post-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-description {
    margin: 0.45rem 0 0.6rem;
    font-size: 1rem;
    line-height: 1.7;
    color: #475569;
    font-weight: 400;
    max-width: 65ch;
  }
</style>
