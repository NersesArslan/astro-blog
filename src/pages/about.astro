---
import Header from "../components/Header.astro";

import "../styles/global.css";
const identity = {
  firstName: "Nerses",
  country: "USA",
  occupation: "Gold Assayer",
  hobbies: [
    "reading",
    "philosophy",
    "literature",
    "brazilian jiu-jitsu",
    "hot yoga",
    " and programming.",
  ],

  education: "American University of Beirut",
  degree: {
    BA: "Political Studies",
    MA: "Philosophy",
  },
};

const skills = [
  "HTML",
  "CSS",
  "JavaScript",
  "React",
  "Astro",
  "academic writing",
];
const pageTitle = "About Me";
import BaseLayout from "../layouts/BaseLayout.astro";
import profilePic from "./public/ images/profile/me2.jpg";
---

<BaseLayout pageTitle={pageTitle}>
  <img src={profilePic.src} class="profile" alt="My grandmother and me" />
  <p>Here are a few facts about me:</p>

  <ul>
    <li>My name is {identity.firstName}.</li>
    <li>
      I live in the {identity.country} and I work as a {identity.occupation}.
    </li>
    {
      identity.hobbies.length >= 2 && (
        <li>Some of my hobbies are: {identity.hobbies.join(", ")}</li>
      )
    }
  </ul>
  <p>My skills are:</p>
  <ul>
    {skills.map((skill) => <li>{skill}</li>)}
  </ul>
</BaseLayout>
